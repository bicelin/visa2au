# Cloudflare Pages headers — security + caching (deploy-ready)

/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=("https://*.daily.co"), geolocation=(), payment=(self), microphone=(self "https://*.elevenlabs.io" "https://*.daily.co")
  Cross-Origin-Opener-Policy: same-origin
  Link: </.well-known/api-catalog>; rel="api-catalog", </llms.txt>; rel="help"; type="text/plain"
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://*.elevenlabs.io https://*.daily.co; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https: wss:; media-src 'self' https:; worker-src 'self' blob:; child-src blob: https://*.elevenlabs.io https://*.daily.co; frame-src https://*.elevenlabs.io https://*.daily.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://visa2au.mmportal.cloud; upgrade-insecure-requests

# API catalog (RFC 9727) — machine-readable linkset
/.well-known/api-catalog
  Content-Type: application/linkset+json
  Cache-Control: public, max-age=3600

# Hashed Astro assets — immutable long cache
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static imagery — 30-day cache (swap to Cloudflare Image Resizing URLs later)
/imgs/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/story/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/emblems/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/motifs/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

# HTML + data — always fresh
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/search-index.json
  Cache-Control: public, max-age=300, must-revalidate
